      ],
      "source": [
        "from pyspark.sql import functions as F\n",
        "from pyspark.sql.functions import hour, date_format, col, unix_timestamp\n",
        "\n",
        "# Step 1: Remove rows with nulls in critical columns\n",
        "# Critical columns: pickup/dropoff times, locations, fare, distance\n",
        "before_count = df.count()\n",
        "df = df.dropna(subset=[\"tpep_pickup_datetime\", \"tpep_dropoff_datetime\",\n",
        "                       \"PULocationID\", \"DOLocationID\",\n",
        "                       \"fare_amount\", \"trip_distance\"])\n",
        "after_nulls = df.count()\n",
        "print(\"Rows removed due to nulls:\", before_count - after_nulls)\n",
        "\n",
        "# Step 2: Filter out invalid trips\n",
        "# Invalid conditions: zero/negative distance, negative fares, fares > $500, dropoff before pickup\n",
        "before_invalid = df.count()\n",
        "df = df.filter((df.trip_distance > 0) &\n",
        "               (df.fare_amount >= 0) &\n",
        "               (df.fare_amount <= 500) &\n",
        "               (df.tpep_dropoff_datetime >= df.tpep_pickup_datetime))\n",
        "after_invalid = df.count()\n",
        "print(\"Rows removed due to invalid trips:\", before_invalid - after_invalid)\n",
        "\n",
        "# Step 3: Create derived columns\n",
        "# trip_duration_minutes: difference between pickup and dropoff timestamps using unix_timestamp\n",
        "df = df.withColumn(\n",
        "    \"trip_duration_minutes\",\n",
        "    (unix_timestamp(\"tpep_dropoff_datetime\") - unix_timestamp(\"tpep_pickup_datetime\")) / 60\n",
        ")\n",
        "\n",
        "# trip_speed_mph: distance divided by duration in hours\n",
        "df = df.withColumn(\n",
        "    \"trip_speed_mph\",\n",
        "    F.when(col(\"trip_duration_minutes\") > 0,\n",
        "           col(\"trip_distance\") / (col(\"trip_duration_minutes\") / 60))\n",
        "     .otherwise(F.lit(0))\n",
        ")\n",
        "\n",
        "# pickup_hour: extract hour from pickup timestamp\n",
        "df = df.withColumn(\"pickup_hour\", hour(col(\"tpep_pickup_datetime\")))\n",
        "\n",
        "# pickup_day_of_week\n",
        "df = df.withColumn(\"pickup_day_of_week\", date_format(col(\"tpep_pickup_datetime\"), \"E\"))\n",
        "\n",
        "# tip_percentage: tip_amount / fare_amount * 100\n",
        "df = df.withColumn(\n",
        "    \"tip_percentage\",\n",
        "    F.when(col(\"fare_amount\") > 0,\n",
        "           (col(\"tip_amount\") / col(\"fare_amount\")) * 100)\n",
        "     .otherwise(F.lit(0))\n",
        ")\n",
        "\n",
        "# Step 4: Print schema to verify new columns\n",
        "df.printSchema()\n"
      ]
    },
