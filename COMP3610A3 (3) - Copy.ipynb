      "source": [
        "from langchain.text_splitter import RecursiveCharacterTextSplitter\n",
        "from sentence_transformers import SentenceTransformer\n",
        "import chromadb\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import os\n",
        "from chromadb.config import Settings\n",
        "\n",
        "\n",
        "# Disable telemetry warnings\n",
        "os.environ[\"ANONYMIZED_TELEMETRY\"] = \"False\"\n",
        "\n",
        "\n",
        "# Step 1: Split text into chunks\n",
        "splitter = RecursiveCharacterTextSplitter(chunk_size=1000, chunk_overlap=200)\n",
        "chunks = splitter.split_documents(documents)\n",
        "\n",
        "print(\"Total chunks created:\", len(chunks))\n",
        "\n",
        "\n",
        "# Step 2: Visualize chunk sizes\n",
        "chunk_lengths = [len(c.page_content) for c in chunks]\n",
        "\n",
        "sns.histplot(chunk_lengths, bins=20, kde=False)\n",
        "plt.title(\"Distribution of Chunk Sizes\")\n",
        "plt.xlabel(\"Chunk length (characters)\")\n",
        "plt.ylabel(\"Frequency\")\n",
        "plt.show()\n",
        "\n",
        "# Step 3: Generate embeddings\n",
        "model = SentenceTransformer(\"all-MiniLM-L6-v2\")\n",
        "\n",
        "# Step 4: Store in ChromaDB\n",
        "chromadb.api.client.SharedSystemClient._identifer_to_system = {}\n",
        "client = chromadb.PersistentClient(path=\"chroma_db\")\n",
        "\n",
        "collection_name = \"transport_docs\"\n",
        "\n",
        "# Delete old collection to prevents duplicate warnings\n",
        "try:\n",
        "    client.delete_collection(name=collection_name)\n",
        "except:\n",
        "    pass\n",
        "\n",
        "collection = client.create_collection(name=collection_name)\n",
        "\n",
        "# Prepare batch data\n",
        "documents_text = [c.page_content for c in chunks]\n",
        "ids = [f\"doc_{i}\" for i in range(len(chunks))]\n",
        "metadatas = [c.metadata for c in chunks]\n",
        "\n",
        "# Batch embedding\n",
        "embeddings = model.encode(documents_text, batch_size=32).tolist()\n",
        "\n",
        "# Store in ChromaDB\n",
        "collection.add(\n",
        "    ids=ids,\n",
        "    documents=documents_text,\n",
        "    embeddings=embeddings,\n",
        "    metadatas=metadatas\n",
        ")\n",
        "\n",
        "print(\"Embeddings stored in ChromaDB:\", collection.count())\n",
        "\n",
        "\n",
        "# Step 5: Chunk size comparison\n",
        "splitters = {\n",
        "    \"500\": RecursiveCharacterTextSplitter(chunk_size=500, chunk_overlap=100),\n",
        "    \"1000\": RecursiveCharacterTextSplitter(chunk_size=1000, chunk_overlap=200),\n",
        "    \"2000\": RecursiveCharacterTextSplitter(chunk_size=2000, chunk_overlap=400)\n",
        "}\n",
        "\n",
        "sample_queries = [\n",
        "    \"What are the TLC regulations on surge pricing?\",\n",
        "    \"How does Vision Zero affect taxi operations?\",\n",
        "    \"What trends are reported in NYC taxi ridership?\"\n",
        "]\n",
        "\n",
        "for size, sp in splitters.items():\n",
        "    test_chunks = sp.split_documents(documents)\n",
        "\n",
        "    # Prepare data\n",
        "    test_docs = [c.page_content for c in test_chunks]\n",
        "    test_ids = [f\"test_{size}_{i}\" for i in range(len(test_chunks))]\n",
        "    test_metas = [c.metadata for c in test_chunks]\n",
        "\n",
        "    # Batch embeddings to allow for processing of the large pdfs\n",
        "    test_embeddings = model.encode(test_docs, batch_size=32).tolist()\n",
        "\n",
        "    # Reset collection each run\n",
        "    try:\n",
        "        client.delete_collection(name=f\"test_{size}\")\n",
        "    except:\n",
        "        pass\n",
        "\n",
        "    temp_collection = client.create_collection(name=f\"test_{size}\")\n",
        "\n",
        "    temp_collection.add(\n",
        "        ids=test_ids,\n",
        "        documents=test_docs,\n",
        "        embeddings=test_embeddings,\n",
        "        metadatas=test_metas\n",
        "    )\n",
        "\n",
        "    print(f\"\\n--- Results for chunk size {size} ---\")\n",
        "\n",
        "    for q in sample_queries:\n",
        "        results = temp_collection.query(query_texts=[q], n_results=3)\n",
        "\n",
        "        print(f\"\\nQuery: {q}\")\n",
        "\n",
        "        for doc, meta in zip(results['documents'][0], results['metadatas'][0]):\n",
        "            source = meta.get(\"source\", \"Unknown\")\n",
        "            page = meta.get(\"page\", \"N/A\")\n",
        "\n",
        "            print(f\"Source: {source} | Page: {page}\")\n",
        "            print(f\"Snippet: {doc[:200]}...\\n\")\n",
        "\n",
        "print(\"Part 2.2 Complete\")"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Looking at the three sample queries across chunk sizes, the retrieval quality shifts noticeably. With chunk size 500 while it did succeed in retreiving the correct topic, the system produced more fragmented but sometimes less relevant snippets, pulling partial sentences that didn’t always answer the query directly. At chunk size 1000, the retrieved chunks were more coherent and consistently tied to the query, giving fuller context. At chunk size 2000, the results were broader but occasionally too general, mixing in background information rather than precise answers. Overall, the 1000 token chunks retrieved the most relevant results because they balanced detail with focus, providing enough context without integrating unrelated material."
      ],
      "metadata": {
        "id": "lhVFijf2WWKT"
      }
    },
