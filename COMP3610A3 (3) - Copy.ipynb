        "import os\n",
        "from langchain_core.prompts import PromptTemplate\n",
        "from langchain_openai import ChatOpenAI\n",
        "from langchain.chains import RetrievalQA\n",
        "from langchain_community.vectorstores import Chroma\n",
        "from langchain_community.embeddings import SentenceTransformerEmbeddings\n",
        "\n",
        "\n",
        "\n",
        "# Step 1: Define a clear prompt\n",
        "prompt_template = \"\"\"\n",
        "You are an assistant answering questions about NYC transportation policy.\n",
        "Use the provided context to answer the question as best as possible.\n",
        "If the context is unclear, explain what is missing but still summarize any relevant information.\n",
        "Always cite the source filename and page number.\n",
        "\n",
        "Question: {question}\n",
        "Context: {context}\n",
        "Answer:\n",
        "\"\"\"\n",
        "\n",
        "prompt = PromptTemplate(\n",
        "    input_variables=[\"question\", \"context\"],\n",
        "    template=prompt_template\n",
        ")\n",
        "\n",
        "\n",
        "# Step 2: Connect to the course LLM server\n",
        "llm = ChatOpenAI(\n",
        "    temperature=0,\n",
        "    openai_api_base=\"https://synapse.sergiomathurin.com/v1\",\n",
        "    openai_api_key=os.getenv(\"LLM_API_KEY\"),   #API key\n",
        "    model=\"llama3-8b-instruct\"\n",
        ")\n",
        "\n",
        "# Step 3: Connect to existing ChromaDB\n",
        "embedding_function = SentenceTransformerEmbeddings(model_name=\"all-MiniLM-L6-v2\")\n",
        "\n",
        "vectorstore = Chroma(\n",
        "    collection_name=\"transport_docs\",\n",
        "    embedding_function=embedding_function,\n",
        "    persist_directory=\"chroma_db\"\n",
        ")\n",
        "\n",
        "retriever = vectorstore.as_retriever(search_kwargs={\"k\": 5})\n",
        "\n",
        "\n",
        "\n",
        "# Step 4: Build the RetrievalQA chain to ensure only relevant info is retrieved and responses are direct\n",
        "qa_chain = RetrievalQA.from_chain_type(\n",
        "    llm=llm,\n",
        "    retriever=retriever,\n",
        "    chain_type=\"stuff\",\n",
        "    chain_type_kwargs={\"prompt\": prompt}\n",
        ")\n",
        "\n",
        "# Step 5: Test the pipeline\n",
        "test_questions = [\n",
        "    \"What policies regulate taxi fares in NYC?\",\n",
        "    \"How does Vision Zero impact taxi operations?\",\n",
        "    \"What trends are reported in TLC annual ridership?\",\n",
        "    \"What are the rules on surge pricing?\",\n",
        "    \"How are driver tips and fare structures documented?\"\n",
        "]\n",
        "\n",
        "for q in test_questions:\n",
        "    print(f\"\\nQuestion: {q}\")\n",
        "    result = qa_chain.invoke(q)\n",
        "    print(\"Answer:\", result[\"result\"])\n",
        "\n",
        "    retrieved = retriever.get_relevant_documents(q)\n",
        "    for doc in retrieved[:3]:\n",
        "        print(f\"Source: {doc.metadata.get('source')} | Page: {doc.metadata.get('page')}\")\n",
        "        print(f\"Context snippet: {doc.page_content[:200]}...\\n\")\n"
      ]
    },
