      "source": [
        "*Task 2.1: Document Collection & Ingestion*"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "This cell loads all PDF documents from the docs folder, extracts their text using PyPDFLoader, and reports statistics such as total pages, total characters, and any quality issues to verify the integrity of the document corpus before using it for analysis."
      ],
      "metadata": {
        "id": "7hVf6o--m1xt"
      }
    },
    {
      "cell_type": "code",
      "execution_count": 3,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "e6KRVVNWM9dZ",
        "outputId": "76313e14-d8e0-4af8-b4fe-b09f7c0a8caf"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Total PDFs: 5\n",
            "Total pages extracted: 280\n",
            "Total characters extracted: 744844\n",
            "Quality issues: ['GIZ_SUTP_TD16_Taxi_EN.pdf page 63 may be scanned/garbled']\n"
          ]
        }
      ],
      "source": [
        "from langchain.document_loaders import PyPDFLoader\n",
        "\n",
        "import os\n",
        "\n",
        "# Step 1: Load pdfs using LangChain document loaders to extract text\n",
        "docs_path = \"docs/\"\n",
        "pdf_files = [f for f in os.listdir(docs_path) if f.endswith(\".pdf\")]\n",
        "\n",
        "total_pages = 0\n",
        "total_chars = 0\n",
        "quality_issues = []\n",
        "\n",
        "documents = []\n",
        "\n",
        "for pdf in pdf_files:\n",
        "    loader = PyPDFLoader(os.path.join(docs_path, pdf))\n",
        "    pages = loader.load()\n",
        "    documents.extend(pages)\n",
        "\n",
        "    # Step 2: Count pages and characters\n",
        "    total_pages += len(pages)\n",
        "    for p in pages:\n",
        "        text = p.page_content\n",
        "        total_chars += len(text)\n",
        "        if len(text.strip()) < 50:  # heuristic for poor extraction\n",
        "            quality_issues.append(f\"{pdf} page {p.metadata['page']} may be scanned/garbled\")\n",
        "\n",
        "print(\"Total PDFs:\", len(pdf_files))\n",
        "print(\"Total pages extracted:\", total_pages)\n",
        "print(\"Total characters extracted:\", total_chars)\n",
        "print(\"Quality issues:\", quality_issues if quality_issues else \"None\")\n"
      ]
    },
