      "source": [
        "# Register the cleaned DataFrame as a temporary SQL view\n",
        "df.createOrReplaceTempView(\"trips\")\n",
        "\n",
        "# Query 1: Top 10 busiest pickup hours with average fare and tip percentage\n",
        "query1 = \"\"\"\n",
        "SELECT pickup_hour,\n",
        "       COUNT(*) AS trip_count,\n",
        "       AVG(fare_amount) AS avg_fare,\n",
        "       AVG(tip_percentage) AS avg_tip_pct\n",
        "FROM trips\n",
        "GROUP BY pickup_hour\n",
        "ORDER BY trip_count DESC\n",
        "LIMIT 10\n",
        "\"\"\"\n",
        "result1 = spark.sql(query1)\n",
        "result1.show()\n",
        "\n",
        "# Query 2: Day of week with highest average trip speed, including avg distance and duration\n",
        "query2 = \"\"\"\n",
        "SELECT pickup_day_of_week,\n",
        "       AVG(trip_speed_mph) AS avg_speed,\n",
        "       AVG(trip_distance) AS avg_distance,\n",
        "       AVG(trip_duration_minutes) AS avg_duration\n",
        "FROM trips\n",
        "GROUP BY pickup_day_of_week\n",
        "ORDER BY avg_speed DESC\n",
        "LIMIT 1\n",
        "\"\"\"\n",
        "result2 = spark.sql(query2)\n",
        "result2.show()\n",
        "\n",
        "\n",
        "#Query 3: Rank top 5 pickup locations by total revenue for each day of week\n",
        "query3 = \"\"\"WITH ranked AS (\n",
        "    SELECT pickup_day_of_week,\n",
        "           PULocationID,\n",
        "           SUM(fare_amount + tip_amount) AS total_revenue,\n",
        "           RANK() OVER (\n",
        "               PARTITION BY pickup_day_of_week\n",
        "               ORDER BY SUM(fare_amount + tip_amount) DESC\n",
        "           ) AS rank\n",
        "    FROM trips\n",
        "    GROUP BY pickup_day_of_week, PULocationID\n",
        ")\n",
        "SELECT pickup_day_of_week, PULocationID, total_revenue, rank\n",
        "FROM ranked\n",
        "WHERE rank <= 5 \"\"\"\n",
        "result3 = spark.sql(query3)\n",
        "result3.show()\n",
        "\n",
        "# Query 4: Cumulative trip count by hour of day\n",
        "query4 = \"\"\"\n",
        "WITH hourly_counts AS (\n",
        "    SELECT pickup_hour, COUNT(*) AS trips\n",
        "    FROM trips\n",
        "    GROUP BY pickup_hour\n",
        "),\n",
        "cumulative AS (\n",
        "    SELECT pickup_hour,\n",
        "           trips,\n",
        "           SUM(trips) OVER (ORDER BY pickup_hour) AS cumulative_trips\n",
        "    FROM hourly_counts\n",
        ")\n",
        "SELECT pickup_hour, trips, cumulative_trips\n",
        "FROM cumulative\n",
        "\"\"\"\n",
        "result4 = spark.sql(query4)\n",
        "result4.show()\n",
        "\n",
        "# Query 5: Compare average fare, distance, and tip percentage by trip category\n",
        "query5 = \"\"\"\n",
