        "import time\n",
        "import pandas as pd\n",
        "from pyspark.sql import SparkSession\n",
        "import requests\n",
        "\n",
        "# Step 1: Download the dataset programmatically\n",
        "url = \"https://d37ci6vzurychx.cloudfront.net/trip-data/yellow_tripdata_2024-01.parquet\"\n",
        "filename = \"yellow_tripdata_2024-01.parquet\"\n",
        "\n",
        "with open(filename, \"wb\") as f:\n",
        "    f.write(requests.get(url).content)\n",
        "\n",
        "# Step 2: Create a SparkSession with adaptive query execution enabled\n",
        "spark = SparkSession.builder \\\n",
        "    .appName(\"COMP3610_Assignment3\") \\\n",
        "    .config(\"spark.sql.adaptive.enabled\", \"true\") \\\n",
        "    .config(\"spark.executor.memory\", \"2g\") \\\n",
        "    .getOrCreate()\n",
        "\n",
        "# Step 3: Load the Parquet file into Spark and measure load time\n",
        "start = time.time()\n",
        "df = spark.read.parquet(filename)\n",
        "spark_time = time.time() - start\n",
        "\n",
        "# Display schema to verify column types\n",
        "df.printSchema()\n",
        "\n",
        "# Report row count and partition count\n",
        "print(\"Row count:\", df.count())\n",
        "print(\"Partition count:\", df.rdd.getNumPartitions())\n",
        "\n",
        "# Step 4: Compare load time against Pandas\n",
        "start = time.time()\n",
        "pdf = pd.read_parquet(filename)\n",
        "pandas_time = time.time() - start\n",
        "\n",
        "print(f\"Spark load time: {spark_time:.2f} seconds\")\n",
        "print(f\"Pandas load time: {pandas_time:.2f} seconds\")\n"
      ]
